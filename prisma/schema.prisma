generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @unique
  description  String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  environments Environment[]
  flags        Flag[]
  segments     Segment[]
  auditLogs    AuditLog[]

  @@map("projects")
}

model Environment {
  id           String        @id @default(uuid()) @db.Uuid
  projectId    String        @map("project_id") @db.Uuid
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key          String
  name         String
  color        String?
  apiKey       String        @unique @map("api_key")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  flagVersions FlagVersion[]
  events       Event[]
  auditLogs    AuditLog[]

  @@unique([projectId, key])
  @@map("environments")
}

model Flag {
  id             String          @id @default(uuid()) @db.Uuid
  projectId      String          @map("project_id") @db.Uuid
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key            String
  name           String
  description    String?
  archived       Boolean         @default(false)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  flagVersions   FlagVersion[]
  flagVariations FlagVariation[]
  events         Event[]

  @@unique([projectId, key])
  @@map("flags")
}

model FlagVariation {
  id        String   @id @default(uuid()) @db.Uuid
  flagId    String   @map("flag_id") @db.Uuid
  flag      Flag     @relation(fields: [flagId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  events    Event[]

  @@unique([flagId, key])
  @@map("flag_variations")
}

model FlagVersion {
  id             String          @id @default(uuid()) @db.Uuid
  flagId         String          @map("flag_id") @db.Uuid
  flag           Flag            @relation(fields: [flagId], references: [id], onDelete: Cascade)
  environmentId  String          @map("environment_id") @db.Uuid
  environment    Environment     @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  version        Int
  isEnabled      Boolean         @default(false) @map("is_enabled")
  compiled       Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at")
  targetingRules TargetingRule[]

  @@unique([flagId, environmentId, version])
  @@map("flag_versions")
}

model TargetingRule {
  id            String      @id @default(uuid()) @db.Uuid
  flagVersionId String      @map("flag_version_id") @db.Uuid
  flagVersion   FlagVersion @relation(fields: [flagVersionId], references: [id], onDelete: Cascade)
  orderIndex    Int         @map("order_index")
  condition     Json
  rollout       Json
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("targeting_rules")
}

model Segment {
  id           String        @id @default(uuid()) @db.Uuid
  projectId    String        @map("project_id") @db.Uuid
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key          String
  name         String
  description  String?
  // Rule-based segment conditions (JSON array of conditions)
  rules        Json          @default("[]")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")
  segmentUsers SegmentUser[]

  @@unique([projectId, key])
  @@map("segments")
}

model SegmentUser {
  id        String  @id @default(uuid()) @db.Uuid
  segmentId String  @map("segment_id") @db.Uuid
  segment   Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  userKey   String  @map("user_key")

  @@unique([segmentId, userKey])
  @@map("segment_users")
}

model User {
  key        String @id
  attributes Json   @default("{}")

  @@map("users")
}

// Lưu ý: Bảng Event này bỏ qua Partition của SQL để Prisma có thể chạy được.
model Event {
  id            BigInt        @id @default(autoincrement())
  environmentId String        @map("environment_id") @db.Uuid
  environment   Environment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  flagId        String        @map("flag_id") @db.Uuid
  flag          Flag          @relation(fields: [flagId], references: [id], onDelete: Cascade)
  variationId   String        @map("variation_id") @db.Uuid
  flagVariation FlagVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  userKey       String        @map("user_key")
  timestamp     DateTime      @default(now())
  data          Json

  @@map("events")
}

model AuditLog {
  id            String       @id @default(uuid()) @db.Uuid
  projectId     String       @map("project_id") @db.Uuid
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId String?      @map("environment_id") @db.Uuid
  environment   Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  entityType    String       @map("entity_type")
  entityId      String?      @map("entity_id") @db.Uuid
  action        String
  actor         String
  diff          Json
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("audit_logs")
}

model FlagSchedule {
  id            String      @id @default(uuid()) @db.Uuid
  flagVersionId String      @map("flag_version_id") @db.Uuid
  action        String      // "enable" | "disable" | "update_rollout"
  scheduledAt   DateTime    @map("scheduled_at")
  executedAt    DateTime?   @map("executed_at")
  status        String      @default("pending") // "pending" | "executed" | "failed" | "cancelled"
  payload       Json        @default("{}")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("flag_schedules")
}

model Webhook {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String
  url         String
  secret      String?
  events      String[] // ["flag.created", "flag.updated", "flag.toggled"]
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("webhooks")
}

// Analytics aggregate table for fast dashboard queries
model FlagAnalytics {
  id              String   @id @default(uuid()) @db.Uuid
  environmentId   String   @map("environment_id") @db.Uuid
  flagKey         String   @map("flag_key")
  variationKey    String   @map("variation_key")
  date            DateTime @db.Date
  evaluationCount Int      @default(0) @map("evaluation_count")
  uniqueUsers     Int      @default(0) @map("unique_users")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([environmentId, flagKey, variationKey, date])
  @@index([environmentId, date])
  @@index([flagKey, date])
  @@map("flag_analytics")
}

// User role for RBAC
model UserAccount {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("developer") // admin, developer, product_manager, qa, analyst
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  // Project-level permissions
  projectAccess ProjectAccess[]
  resetTokens   PasswordResetToken[]

  @@map("user_accounts")
}

model PasswordResetToken {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String      @unique
  expiresAt DateTime    @map("expires_at")
  usedAt    DateTime?   @map("used_at")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// Project-level access control
model ProjectAccess {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String      @map("project_id") @db.Uuid
  role      String      @default("developer") // admin, developer, product_manager, qa, analyst
  createdAt DateTime    @default(now()) @map("created_at")

  @@unique([userId, projectId])
  @@map("project_access")
}

// Session for auth
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}
