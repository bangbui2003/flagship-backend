# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/flagship?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=8080
NODE_ENV=development

# CORS (Frontend URL)
CORS_ORIGIN="http://localhost:3000"

